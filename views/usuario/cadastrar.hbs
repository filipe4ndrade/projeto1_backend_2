<div class="row justify-content-center">
  <div class="col-md-6">

    <h2 class="mb-4">Cadastro de Usuário</h2>

    {{#if erros}}
    <div class="alert alert-danger" role="alert">
      <strong>Corrija os erros abaixo:</strong>
      <ul class="mb-0 mt-2">
        {{#each erros}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    <form action="/usuarios/cadastrar" method="POST">

      <div class="row">
        <div class="col-md-6 mb-3">
          <label for="nome" class="form-label">Nome Completo</label>
          <input type="text" class="form-control" id="nome" name="nome"
                 value="{{valores.nome}}" placeholder="Seu nome completo">
        </div>
        <div class="col-md-6 mb-3">
          <label for="email" class="form-label">Email</label>
          <input type="email" class="form-control" id="email" name="email"
                 value="{{valores.email}}" placeholder="seu@email.com">
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label for="senha" class="form-label">Senha</label>
          <input type="password" class="form-control" id="senha" name="senha"
                 placeholder="Mínimo 6 caracteres">
        </div>
        <div class="col-md-6 mb-3">
          <label for="confirmar_senha" class="form-label">Confirmar Senha</label>
          <input type="password" class="form-control" id="confirmar_senha" name="confirmar_senha"
                 placeholder="Repita a senha">
        </div>
      </div>

      <div class="mt-2">
        <button type="submit" class="btn btn-primary">Cadastrar</button>
        <a href="/usuarios/login" class="btn btn-link">Já possui conta? Faça login</a>
      </div>
      <div class="mt-2">
        <a href="/" class="btn btn-secondary">Voltar</a>
      </div>

    </form>
  </div>
</div>
