<h4 class="mb-4 fw-bold text-secondary">Produtos Cadastrados</h4>

{{#if produtos.length}}
<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead style="background-color: #f8f9fa;">
      <tr>
        <th class="fw-bold">Categoria</th>
        <th class="fw-bold">Nome</th>
        <th class="fw-bold">Qtd.</th>
        <th class="fw-bold">Preço (R$)</th>
        <th class="fw-bold text-center">Ações</th>
      </tr>
    </thead>
    <tbody>
      {{#each produtos}}
      <tr>
        <td>{{this.categoria_nome}}</td>
        <td>{{this.nome}}</td>
        <td>{{this.quantidade}}</td>
        <td>{{this.preco}}</td>
        <td class="text-center">
          <div class="d-flex flex-column align-items-center gap-1">
            <a href="/produtos/consultar/{{this.id}}" class="btn btn-secondary btn-sm w-100">
              <i class="bi bi-eye me-1"></i>Consultar
            </a>

            {{#if ../isLojista}}
              {{#if this.quantidade}}
              <form action="/produtos/vender/{{this.id}}" method="POST" class="w-100">
                <button type="submit" class="btn btn-danger btn-sm w-100">
                  <i class="bi bi-cart-dash me-1"></i>Registrar Venda
                </button>
              </form>
              {{/if}}
              <form action="/produtos/comprar/{{this.id}}" method="POST" class="w-100">
                <button type="submit" class="btn btn-success btn-sm w-100">
                  <i class="bi bi-cart-plus me-1"></i>Registrar Compra
                </button>
              </form>
            {{/if}}
          </div>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{else}}
<div class="alert alert-info mt-3" role="alert">
  <i class="bi bi-info-circle me-2"></i>Nenhum produto cadastrado ainda. O estoque está vazio.
</div>
{{/if}}
