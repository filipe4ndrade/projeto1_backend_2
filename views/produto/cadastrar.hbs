<h2 class="mb-4">Cadastrar Produto</h2>

{{#if erros}}
<div class="alert alert-danger" role="alert">
  <strong>Corrija os erros abaixo:</strong>
  <ul class="mb-0 mt-2">
    {{#each erros}}
    <li>{{this}}</li>
    {{/each}}
  </ul>
</div>
{{/if}}

<form action="/produtos/cadastrar" method="POST">

  <div class="row">
    <div class="col-md-8 mb-3">
      <label for="nome" class="form-label">Nome do Produto</label>
      <input type="text" class="form-control" id="nome" name="nome"
             value="{{valores.nome}}" placeholder="Ex.: Notebook Dell Inspiron 15">
    </div>
    <div class="col-md-4 mb-3">
      <label for="preco" class="form-label">Preço (R$)</label>
      <input type="number" step="0.01" min="0" class="form-control" id="preco" name="preco"
             value="{{valores.preco}}" placeholder="Ex.: 2999.90">
    </div>
  </div>

  <div class="mb-3">
    <label for="descricao" class="form-label">Descrição</label>
    <textarea class="form-control" id="descricao" name="descricao"
              rows="3" placeholder="Descreva o produto...">{{valores.descricao}}</textarea>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <label for="quantidade" class="form-label">Quantidade em Estoque</label>
      <input type="number" min="0" class="form-control" id="quantidade" name="quantidade"
             value="{{valores.quantidade}}" placeholder="Ex.: 10">
    </div>

    <div class="col-md-4 mb-3">
      <label for="status" class="form-label">Status</label>
      <select class="form-select" id="status" name="status">
        <option value="">Selecione...</option>
        <option value="ativo" {{#if (eq valores.status "ativo")}}selected{{/if}}>Ativo</option>
        <option value="inativo" {{#if (eq valores.status "inativo")}}selected{{/if}}>Inativo</option>
      </select>
    </div>

    <div class="col-md-4 mb-3">
      <label for="categoria_id" class="form-label">Categoria</label>
      <select class="form-select" id="categoria_id" name="categoria_id">
        <option value="">Selecione...</option>
        {{#each categorias}}
        <option value="{{this.id}}" {{#if (eq ../valores.categoria_id this.id)}}selected{{/if}}>
          {{this.nome}}
        </option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="mt-2">
    <button type="submit" class="btn btn-primary">Cadastrar Produto</button>
  </div>
  <div class="mt-2">
    <a href="/" class="btn" style="background-color: #0f6dfa; color: #fff;">Voltar</a>
  </div>

</form>
