<h5 class="mb-4 fw-bold text-secondary">Detalhes do Produto</h5>

<div style="background:#fff; border:1px solid #e0e0e0; border-radius:6px; overflow:hidden;">
  <ul class="list-group list-group-flush">
    <li class="list-group-item d-flex">
      <span style="font-weight:600; min-width:180px;">Nome:</span>
      <span>{{produto.nome}}</span>
    </li>
    <li class="list-group-item d-flex">
      <span style="font-weight:600; min-width:180px;">Categoria:</span>
      <span>{{produto.categoria_nome}}</span>
    </li>
    <li class="list-group-item d-flex">
      <span style="font-weight:600; min-width:180px;">Preço:</span>
      <span>R$ {{produto.preco}}</span>
    </li>
    <li class="list-group-item d-flex">
      <span style="font-weight:600; min-width:180px;">Descrição:</span>
      <span>{{produto.descricao}}</span>
    </li>
    <li class="list-group-item d-flex">
      <span style="font-weight:600; min-width:180px;">Quantidade em Estoque:</span>
      <span>{{produto.quantidade}}</span>
    </li>
    <li class="list-group-item d-flex">
      <span style="font-weight:600; min-width:180px;">Status:</span>
      <span>{{produto.status}}</span>
    </li>
  </ul>
</div>

<div class="mt-4">
  <a href="/" class="btn btn-secondary">Voltar</a>
</div>
