<div class="row justify-content-center mt-5">
  <div class="col-md-6 text-center">
    <h1 class="display-4">{{message}}</h1>
    <p class="lead text-muted">Código: {{error.status}}</p>
    {{#if error.stack}}
    <pre class="text-start bg-light p-3 rounded small">{{error.stack}}</pre>
    {{/if}}
    <a href="/" class="btn btn-secondary mt-3">Voltar para a Página Principal</a>
  </div>
</div>
